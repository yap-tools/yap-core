{
  "name": "yap-core",
  "version": "0.1.0",
  "description": "Yap: API-first, self-hosted, navigable context for AI agents over MCP and REST.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "preview:widgets": "tsx watch scripts/preview-widgets.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate --config drizzle-sqlite.config.ts && drizzle-kit generate --config drizzle-pg.config.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1065.0",
    "@aws-sdk/s3-request-presigner": "^3.1065.0",
    "better-sqlite3": "^12.10.0",
    "drizzle-orm": "^0.45.2",
    "fastmcp": "^4.1.0",
    "flydrive": "^2.1.0",
    "pg": "^8.21.0",
    "undici": "^7.27.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.2",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
