# Copy to .env and fill in (or run `yap init`, which generates a config like
# this under ~/.yap for installed use). The server loads the first env file
# that exists — YAP_ENV_FILE, ./.env, $YAP_HOME/.env — with Node's built-in
# parser. Real environment variables override these, so in a deployment you
# can inject secrets via the environment and leave this for local dev only.
# Generate a master key with: openssl rand -base64 32

# --- Required ---------------------------------------------------------------
# Environment credential for user provisioning over REST (>= 16 chars).
# Authenticates the REST API only, never MCP.
YAP_SYSADMIN_KEY=change-me-at-least-16-chars
# Base64-encoded 32 bytes: hook-secret encryption + link/token signing.
YAP_MASTER_KEY=

# --- Listener ---------------------------------------------------------------
YAP_PORT=8787
YAP_HOST=0.0.0.0
# Public origin used when minting absolute file/widget links. Set this to the
# server's externally reachable URL for any non-localhost deployment.
# YAP_BASE_URL=http://localhost:8787

# --- Structured-data store (default: SQLite) --------------------------------
YAP_DB=sqlite
YAP_SQLITE_PATH=./data/yap.db
# For Postgres instead:
# YAP_DB=postgres
# YAP_DATABASE_URL=postgres://user:pass@host:5432/yap

# --- Blob store (default: local disk) ---------------------------------------
YAP_BLOB=fs
YAP_BLOB_FS_ROOT=./data/blobs
# For S3-compatible storage instead:
# YAP_BLOB=s3
# YAP_S3_BUCKET=my-bucket
# YAP_S3_REGION=auto
# YAP_S3_ENDPOINT=https://...        # for R2/MinIO/etc.
# YAP_S3_ACCESS_KEY_ID=
# YAP_S3_SECRET_ACCESS_KEY=
# YAP_S3_FORCE_PATH_STYLE=false

# --- Operational policy (operator-overridable defaults) ---------------------
# YAP_MAX_FILE_SIZE_BYTES=52428800
# YAP_MIME_ALLOWLIST=*                # or e.g. "image/*, application/pdf"
# YAP_UPLOAD_TTL_SECONDS=600
# YAP_DOWNLOAD_TTL_SECONDS=300
# YAP_WIDGET_TOKEN_TTL_SECONDS=600
# YAP_HOOK_TIMEOUT_MS=30000
# YAP_HOOK_ALLOW_HOSTS=               # comma list of internal hosts to permit
# YAP_ORPHAN_SWEEP_INTERVAL_MS=600000
# YAP_ORPHAN_MAX_AGE_MS=3600000

# Optional: force a specific env file (beats ./.env and $YAP_HOME/.env). Set
# these in the real environment — they decide which file gets loaded, so they
# can't live inside it. YAP_HOME (default ~/.yap) moves the installed CLI's
# config + data home.
# YAP_ENV_FILE=.env
